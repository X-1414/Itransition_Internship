<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - The App</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
        <link rel="stylesheet" href="~/css/site.css" />
    </head>

    <body class="auth-body">
        <div class="auth-split">
            <div class="auth-left">@RenderBody()</div>
            <div class="auth-right d-none d-md-flex">
                <div class="auth-right-content">
                    <div class="auth-right-logo">THE APP</div>
                    <p class="auth-right-tagline">Manage your users.<br />Simply and reliably.</p>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js"></script>
        
    </body>
</html>