<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - The App </title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
        <link rel="stylesheet" href="~/css/site.css" />
    </head>

    <body class="d-flex flex-column min-vh-100">
        <nav class="navbar navbar-expand-md navbar-dark bg-primary shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold letter-spaced" href="/">THE APP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        @if (Context.Session.GetInt32("UserId") != null){
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Users</a>
                                </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (Context.Session.GetInt32("UserId") != null){
                            <li class="nav-item me-3 text-white-50 small d-none d-md-block">
                                <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UserName")
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-box-arrow-right me-1"></i>Log out
                                    </button>
                                </form>
                            </li>
                        }
                        else {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        
        <main class="flex-grow-1">
            @RenderBody()
        </main>

        <footer class="py-3 mt-auto border-top bg-light">
            <div class="container-fluid px-4">
                <p class="mb-0 text-muted small">&copy; @DateTime.Now.Year The App</p>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>